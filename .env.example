# Local Codex CLI command. On Windows the default launcher is usually codex.cmd.
CODEX_BIN=

# Optional Codex model override.
CODEX_MODEL=

# Working directory Codex will use.
CODEX_WORKDIR=.

# If true, enables Codex native web search.
CODEX_ENABLE_WEB_SEARCH=true

# If true, Codex runs without sandboxing.
CODEX_DANGEROUS_BYPASS=false

# Sandbox mode used when CODEX_DANGEROUS_BYPASS=false.
CODEX_SANDBOX_MODE=workspace-write

# Max time for a single `codex exec` task before the harness kills it and records a timeout.
CODEX_TASK_TIMEOUT_MS=300000

# Included in task context as non-secret JSON.
# Built-in default includes Base context plus a generic agent profile.
AGENT_CONTEXT_JSON={}
# Example:
# AGENT_CONTEXT_JSON={"chain":"Base","portfolioName":"Main portfolio","walletAddress":"0x...","preferredDexes":["Aerodrome","Uniswap"]}
# Synthesis registration example:
# AGENT_CONTEXT_JSON={"agentProfile":{"name":"Master Trader XYZ","description":"A Codex-driven agent that researches markets, coordinates with its human, and proposes guarded execution plans.","image":"https://example.com/agent.png","agentHarness":"codex-cli","model":"gpt-5.4"}}

# Comma-, semicolon-, or newline-separated env var names that should be resolved into task secrets at runtime.
# Example: AGENT_SECRET_KEYS=PRIVATE_RPC_URL,WALLET_PRIVATE_KEY
AGENT_SECRET_KEYS=

# Transaction guardrails for execution tasks.
# dry-run blocks live transactions even if Codex proposes them.
TRANSACTION_EXECUTION_MODE=dry-run
TRANSACTION_REQUIRE_HUMAN_APPROVAL=true
TRANSACTION_MAX_ACTIONS=3
TRANSACTION_MAX_AMOUNT_PER_ACTION=
TRANSACTION_ALLOWED_ASSETS=
TRANSACTION_BLOCKED_ASSETS=
TRANSACTION_ALLOWED_ACTION_TYPES=
TRANSACTION_BLOCKED_ACTION_TYPES=
TRANSACTION_LIVE_STATUSES=

# Optional skill URLs to seed/refresh into the registry before runs.
# Example: SKILL_URLS=https://example.com/market-research-skill.md,https://example.com/other-skill.md
SKILL_URLS=

# Optional default skill ids to attach to runs.
# Example: DEFAULT_SKILL_IDS=market-research,execution-helper
DEFAULT_SKILL_IDS=

# Optional full workflow override as JSON.
# Example:
# WORKFLOW_CONFIG_JSON={"id":"custom-workflow","name":"Custom Workflow","default_skill_ids":[],"tasks":[...]}

# Optional override for tool-specific skill directories the harness can inspect/integrate.
# Example: SKILL_TARGETS_JSON=[{"tool":"codex","dir":"C:/Users/you/.codex/skills"},{"tool":"cursor","dir":"C:/Users/you/.cursor/skills"}]
SKILL_TARGETS_JSON=
WORKFLOW_CONFIG_JSON=
