{
  "id": "synthesis-entry-workflow",
  "name": "Synthesis Entry Workflow",
  "default_skill_ids": [
    "synthesis"
  ],
  "tasks": [
    {
      "id": "register-for-synthesis",
      "goal": "Register this agent for The Synthesis hackathon, asking for only the minimum human input needed and persisting any pending IDs, participant IDs, team IDs, invite codes, and API credentials returned during the process.",
      "continue_on_blocked": true,
      "preflight_checks": [
        {
          "kind": "http",
          "target": "https://synthesis.devfolio.co/register/init",
          "method": "HEAD",
          "timeout_ms": 5000,
          "inconclusive_status": [404, 405]
        }
      ],
      "skill_ids": [
        "synthesis"
      ],
      "context": {
        "objective": "Become an entered participant in The Synthesis contest.",
        "expected_agent_profile_path": "global.agentProfile",
        "required_human_profile_fields": [
          "humanInfo.name",
          "humanInfo.email",
          "humanInfo.background",
          "humanInfo.cryptoExperience",
          "humanInfo.aiAgentExperience",
          "humanInfo.codingComfort",
          "humanInfo.problemToSolve",
          "humanInfo.verificationMethod"
        ],
        "allowed_verification_methods": [
          "email",
          "twitter"
        ]
      },
      "outputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "snapshot_at",
          "registration_status",
          "verification_method",
          "participant",
          "team",
          "next_step"
        ],
        "properties": {
          "snapshot_at": {
            "type": "string"
          },
          "registration_status": {
            "type": "string"
          },
          "verification_method": {
            "type": "string"
          },
          "participant": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "participant_id",
              "wallet_address"
            ],
            "properties": {
              "participant_id": {
                "type": "string"
              },
              "wallet_address": {
                "type": "string"
              },
              "display_name": {
                "type": "string"
              }
            }
          },
          "team": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "team_id",
              "invite_code"
            ],
            "properties": {
              "team_id": {
                "type": "string"
              },
              "invite_code": {
                "type": "string"
              },
              "role": {
                "type": "string"
              }
            }
          },
          "next_step": {
            "type": "string"
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "id": "prepare-synthesis-submission-plan",
      "goal": "After registration, produce a concise submission plan for The Synthesis contest covering what to build next, what on-chain or demo artifacts are needed, and what evidence of human-agent collaboration should be recorded.",
      "skill_ids": [
        "synthesis"
      ],
      "context": {
        "objective": "Leave the project in a contest-ready planning state after entry.",
        "planning_mode": "If registration is blocked, still produce a provisional submission plan from the known agent context and prior task output."
      },
      "outputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "snapshot_at",
          "entry_readiness",
          "build_targets",
          "submission_requirements",
          "collaboration_log_requirements"
        ],
        "properties": {
          "snapshot_at": {
            "type": "string"
          },
          "entry_readiness": {
            "type": "string"
          },
          "build_targets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "submission_requirements": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "collaboration_log_requirements": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "risks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  ]
}
